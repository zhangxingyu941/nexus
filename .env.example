# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-a-long-random-password
POSTGRES_DB=notion_block_editor
DATABASE_URL=postgresql://postgres:replace-with-a-long-random-password@127.0.0.1:5432/notion_block_editor
DATABASE_SSL=false

# Redis and authentication security
REDIS_URL=redis://127.0.0.1:6379
AUTH_HASH_SECRET=replace-with-at-least-32-random-bytes
# Keep true behind HTTPS/WSS. Use false only for local HTTP/WS acceptance tests.
AUTH_COOKIE_SECURE=true

# Optional GitHub OAuth
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# SMTP is required for six-digit registration and password-reset codes in production.
# Codes expire after 10 minutes; the same account can request one code every 60 seconds.
# Messages include plain-text and QQ Mail-compatible HTML bodies.
# QQ Mail uses an authorization code instead of the account login password.
# SMTP_HOST=smtp.qq.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=your-account@qq.com
# SMTP_PASSWORD=qq-mail-authorization-code
# SMTP_FROM=Nexus <your-account@qq.com>
# E2E only: captures verification codes and takes precedence over SMTP when configured.
# AUTH_MAIL_CAPTURE_FILE=/app/server/data/uploads/auth-mail-capture.jsonl
# AUTH_MAIL_CAPTURE_ALLOW_PRODUCTION=true  # required because the E2E image runs with NODE_ENV=production

# Object storage: local or s3
OBJECT_STORAGE_DRIVER=local
OBJECT_STORAGE_LOCAL_DIR=server/data/uploads
# S3_BUCKET=notion-block-editor
# S3_REGION=us-east-1
# S3_ENDPOINT=https://s3.example.com
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_FORCE_PATH_STYLE=true

# Authenticated collaboration service
COLLAB_HOST=0.0.0.0
COLLAB_PORT=1234
COLLAB_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
COLLAB_YJS_COMPACTION_UPDATES=100
COLLAB_YJS_COMPACTION_BYTES=1048576
NEXT_PUBLIC_COLLABORATION_URL=ws://localhost:1234

# Optional host port overrides for Docker Compose
WEB_PORT=3000
COLLAB_EXTERNAL_PORT=1234

# Optional registry mirrors for restricted networks
# POSTGRES_IMAGE=postgres:16-alpine
# REDIS_IMAGE=redis:7-alpine
# NODE_IMAGE=node:20-alpine

# Legacy JSON import owner
MIGRATION_USER_NAME=Workspace Owner
MIGRATION_USER_EMAIL=owner@example.com
