services:
  postgres:
    image: docker.m.daocloud.io/library/postgres:16-alpine
    ports:
      - "127.0.0.1:5432:5432"

  redis:
    image: docker.m.daocloud.io/library/redis:7-alpine
    ports:
      - "127.0.0.1:6379:6379"

  web:
    build:
      args:
        NODE_IMAGE: docker.m.daocloud.io/library/node:20-alpine

  collaboration:
    build:
      args:
        NODE_IMAGE: docker.m.daocloud.io/library/node:20-alpine

  migrate:
    build:
      args:
        NODE_IMAGE: docker.m.daocloud.io/library/node:20-alpine
